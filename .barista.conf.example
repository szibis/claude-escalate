# =============================================================================
# Barista Configuration
# =============================================================================
# Generated by install.sh
# Enable/disable modules by setting to "true" or "false"
# For full configuration options, see barista.conf in the repo
# =============================================================================

# Global Settings
USE_ICONS="true"
DISPLAY_MODE="normal"
STATUS_STYLE="emoji"
PROGRESS_BAR_FILLED="█"
PROGRESS_BAR_EMPTY="░"
SEPARATOR=" │ "
USE_ANSI_FORMAT="true"
COLOR_THEME="default"

# Module Settings
MODULE_SANDBOX="true"
MODULE_VERSION="true"
MODULE_UPDATE="true"
MODULE_DIRECTORY="true"
MODULE_CONTEXT="true"
MODULE_GIT="true"
MODULE_PROJECT="true"
MODULE_MODEL="true"
MODULE_COST="true"
MODULE_RATE_LIMITS="true"
MODULE_TIME="false"
MODULE_BATTERY="false"
MODULE_CPU="false"
MODULE_MEMORY="false"
MODULE_DISK="false"
MODULE_NETWORK="false"
MODULE_UPTIME="false"
MODULE_LOAD="false"
MODULE_TEMPERATURE="false"
MODULE_BRIGHTNESS="false"
MODULE_PROCESSES="false"
MODULE_DOCKER="false"
MODULE_NODE="false"
MODULE_WEATHER="false"
MODULE_TIMEZONE="false"

# Custom Integration Modules
MODULE_RTK_SAVINGS="true"
MODULE_SCRAPLING_STATS="true"
MODULE_OBSCURA_STATS="true"
MODULE_CLAUDE_MEM_STATUS="true"
MODULE_TOOLS_STATUS="false"
MODULE_PROMPT_CACHE="true"
MODULE_AUTO_EFFORT="false"
MODULE_MODEL_ROUTING="false"
MODULE_ESCALATION_STATUS="true"

# Module display order (comma-separated)
MODULE_ORDER="sandbox,directory,context,rate-limits,cost,claude-mem-status,prompt-cache,escalation-status,rtk-savings,scrapling-stats,obscura-stats,tools-status,model,git,battery"

# =============================================================================
# Display Settings
# =============================================================================

PROGRESS_BAR_WIDTH=8

# =============================================================================
# Layout Settings
# =============================================================================

# Smart wrapping using full terminal width
LAYOUT_MODE="smart"
MAX_LINE_PERCENT=175

# Allow longer directory names before truncation
DIRECTORY_MAX_LENGTH=40

# Context: warn at 50%, critical/compact at 60%
CONTEXT_WARNING_THRESHOLD=50
CONTEXT_CRITICAL_THRESHOLD=60
CONTEXT_COMPACT_THRESHOLD=60

# Key modules: keep details
RATE_SHOW_TIME_REMAINING="true"
RATE_COMPACT="false"
COST_COMPACT="false"
CACHE_COMPACT="false"
RTK_COMPACT="false"

# Secondary modules: compact to save space
GIT_COMPACT="true"
MODEL_COMPACT="true"
TIME_COMPACT="true"
CMEM_COMPACT="false"
SCRP_COMPACT="false"
OBSCURA_COMPACT="false"
EFFORT_COMPACT="true"
ROUTING_COMPACT="true"

# Context: show remaining but skip token breakdown (saves ~15 chars)
CONTEXT_SHOW_BREAKDOWN="false"
CONTEXT_SHOW_TOKENS_REMAINING="true"

# =============================================================================
# Advanced Settings
# =============================================================================

# Cache duration for expensive operations (seconds)
CACHE_MAX_AGE=60

# Enable debug logging
DEBUG_MODE="false"

# =============================================================================
# Per-Directory Overrides
# =============================================================================
# Barista supports per-directory configuration overrides.
# Create a .barista.conf file in any project directory to override settings
# for that project only. This is useful for:
#   - Minimal statusline in large monorepos
#   - Different modules for different project types
#   - Disabling slow modules in certain directories
