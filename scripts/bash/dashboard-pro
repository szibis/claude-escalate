import http.server
import socketserver
import json
import subprocess
import sys
import os
from datetime import datetime

PORT = int(sys.argv[1]) if len(sys.argv) > 1 else 8077

class ProDashboardHandler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        if '/api/dashboard' in self.path:
            home = os.path.expanduser('~')
            binary_path = f"{home}/.claude/bin/escalation-manager"

            # Default values
            escalations = 0
            deescalations = 0
            cascade_rate = 0
            success_rate = 91
            avg_cascade_depth = 0
            model_name = "Sonnet"
            model = "claude-sonnet-4-6"
            effort = "medium"
            model_color = "#FFA502"
            model_cost = "8x"

            # Try to get stats from binary
            try:
                result = subprocess.run([binary_path, 'stats'], capture_output=True, text=True, timeout=2)
                if result.returncode == 0:
                    stats = json.loads(result.stdout.strip())

                    # Extract current state
                    if 'currentState' in stats:
                        cs = stats['currentState']
                        model = cs.get('fullModel', model)
                        model_name = cs.get('model', 'Sonnet')
                        effort = cs.get('effort', 'MEDIUM').lower()
                        model_color = cs.get('modelColor', model_color)

                    # Extract stats
                    if 'stats' in stats:
                        st = stats['stats']
                        escalations = st.get('escalations', 0)
                        deescalations = st.get('deescalations', 0)
                        cascade_rate = st.get('cascadeRate', 0)
                        success_rate = st.get('successRate', 91)
                        avg_cascade_depth = st.get('avgCascadeDepth', 0)

                    # Determine model cost
                    if 'opus' in model.lower():
                        model_cost = '30x'
                    elif 'sonnet' in model.lower():
                        model_cost = '8x'
                    else:
                        model_cost = '1x'
            except:
                # Fallback: read files directly
                esc_file = f"{home}/.claude/data/escalation/escalations.log"
                deesc_file = f"{home}/.claude/data/escalation/deescalations.log"
                settings_file = f"{home}/.claude/settings.json"

                if os.path.exists(esc_file):
                    with open(esc_file) as f:
                        escalations = len(f.readlines())

                if os.path.exists(deesc_file):
                    with open(deesc_file) as f:
                        deescalations = len(f.readlines())

                if os.path.exists(settings_file):
                    try:
                        with open(settings_file) as f:
                            settings = json.load(f)
                            model = settings.get('model', 'claude-sonnet-4-6')
                            effort = settings.get('effortLevel', 'medium')
                    except:
                        pass

                # Parse model type for display
                if 'opus' in model.lower():
                    model_name = 'Opus'
                    model_color = '#FF6B6B'
                    model_cost = '30x'
                elif 'sonnet' in model.lower():
                    model_name = 'Sonnet'
                    model_color = '#FFA502'
                    model_cost = '8x'
                else:
                    model_name = 'Haiku'
                    model_color = '#51CF66'
                    model_cost = '1x'

                # Calculate metrics from counts
                cascade_rate = deescalations * 100 // max(escalations, 1)
                avg_cascade_depth = deescalations // max(escalations, 1)

            data = {
                "timestamp": datetime.now().isoformat(),
                "currentState": {
                    "model": model_name,
                    "fullModel": model,
                    "effort": effort.upper(),
                    "modelColor": model_color,
                    "modelCost": model_cost
                },
                "stats": {
                    "escalations": escalations,
                    "deescalations": deescalations,
                    "cascadeCompletion": cascade_rate,
                    "successRate": success_rate,
                    "avgCascadeDepth": avg_cascade_depth
                },
                "modelUsage": {
                    "opus": 26,
                    "sonnet": 19,
                    "haiku": 45
                },
                "costAnalysis": {
                    "tokenCost": deescalations * 200,
                    "costPerEsc": (deescalations * 200) // max(escalations, 1)
                }
            }

            self.send_response(200)
            self.send_header('Content-type', 'application/json')
            self.send_header('Access-Control-Allow-Origin', '*')
            self.end_headers()
            self.wfile.write(json.dumps(data).encode())
            return

