package service

import (
	"encoding/json"
	"fmt"
	"net/http"
	"strconv"
	"time"

	"github.com/szibis/claude-escalate/internal/analytics"
)

// Analytics endpoints expose 3-phase data: estimation, real-time, validation + learning

// handleAnalyticsPhase1 returns Phase 1 estimation data (pre-response).
func (s *Service) handleAnalyticsPhase1(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		http.Error(w, "method not allowed", http.StatusMethodNotAllowed)
		return
	}

	validationID := r.URL.Query().Get("id")
	if validationID == "" {
		http.Error(w, "missing validation ID", http.StatusBadRequest)
		return
	}

	// Get analytics store
	analyticsStore := analytics.NewStore(s.db.GetDB())

	record, err := analyticsStore.GetRecord(validationID)
	if err != nil {
		http.Error(w, fmt.Sprintf("record not found: %v", err), http.StatusNotFound)
		return
	}

	w.Header().Set("Content-Type", "application/json")
	response := map[string]interface{}{
		"phase":           1,
		"validation_id":   record.ValidationID,
		"timestamp":       record.Timestamp.Format("2006-01-02T15:04:05Z07:00"),
		"prompt_analysis": map[string]interface{}{
			"task_type":           record.Phase1.TaskType,
			"effort":              record.Phase1.DetectedEffort,
			"complexity":          record.Phase1.Complexity,
			"sentiment_baseline":  record.Phase1.SentimentBaseline,
		},
		"estimation": map[string]interface{}{
			"estimated_input_tokens":  record.Phase1.EstimatedInputTokens,
			"estimated_output_tokens": record.Phase1.EstimatedOutputTokens,
			"estimated_total_tokens":  record.Phase1.EstimatedTotalTokens,
			"estimated_cost_usd":      record.Phase1.EstimatedCostUSD,
		},
		"budget_check": map[string]interface{}{
			"within_budget":   record.Phase1.BudgetCheck.WithinBudget,
			"daily_used":      record.Phase1.BudgetCheck.DailyUsed,
			"daily_limit":     record.Phase1.BudgetCheck.DailyLimit,
			"warning":         record.Phase1.BudgetCheck.Warning,
		},
		"routing_decision": map[string]interface{}{
			"routed_model": record.Phase1.RoutedModel,
			"routing_reason": record.Phase1.RoutingReason,
			"confidence":   record.Phase1.Confidence,
		},
	}

	if err := json.NewEncoder(w).Encode(response); err != nil {
		fmt.Printf("error encoding response: %v\n", err)
	}
}

// handleAnalyticsPhase2 returns Phase 2 real-time data (during response).
func (s *Service) handleAnalyticsPhase2(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		http.Error(w, "method not allowed", http.StatusMethodNotAllowed)
		return
